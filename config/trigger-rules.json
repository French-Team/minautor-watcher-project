{
  "autoCorrect": {
    "enabled": true,
    "maxFileSize": "1MB",
    "timeout": 30000,
    "retryAttempts": 3
  },
  "corrections": [
    {
      "ruleId": "prefer-const",
      "enabled": true,
      "action": "replace",
      "pattern": "let ",
      "replacement": "const ",
      "description": "Replace let with const when appropriate"
    },
    {
      "ruleId": "no-console-logs",
      "enabled": true,
      "action": "replace",
      "pattern": "console.log(",
      "replacement": "logger.info(",
      "description": "Replace console.log with Winston logger"
    },
    {
      "ruleId": "no-console-warn",
      "enabled": true,
      "action": "replace",
      "pattern": "console.warn(",
      "replacement": "logger.warn(",
      "description": "Replace console.warn with Winston logger"
    },
    {
      "ruleId": "no-console-error",
      "enabled": true,
      "action": "replace",
      "pattern": "console.error(",
      "replacement": "logger.error(",
      "description": "Replace console.error with Winston logger"
    },
    {
      "ruleId": "eslint-auto-fix",
      "enabled": true,
      "action": "run-eslint-fix",
      "description": "Run ESLint --fix for auto-fixable issues"
    },
    {
      "ruleId": "prettier-format",
      "enabled": true,
      "action": "run-prettier",
      "extensions": ["js", "ts", "jsx", "tsx", "json", "md"],
      "description": "Format code with Prettier"
    }
  ],
  "notifications": {
    "onSuccess": false,
    "onFailure": true,
    "channels": ["console"],
    "throttle": 300000
  },
  "conditions": [
    {
      "name": "file-too-large",
      "condition": "fileSize > maxFileSize",
      "action": "skip",
      "notify": true
    },
    {
      "name": "too-many-attempts",
      "condition": "retryCount >= retryAttempts",
      "action": "notify",
      "notify": true
    }
  ]
}
