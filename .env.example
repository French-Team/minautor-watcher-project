# =============================================================================
# watcher-service - Environment Variables
# =============================================================================
# Copy this file to .env and adjust values as needed.
# All variables are optional — defaults are shown in comments.
# =============================================================================

# --- Watcher / Core ---
# WATCH_DIR=./src                       # Directory to watch for file changes
# EXCLUDED_DIRS=node_modules,.git,dist,build  # Comma-separated dirs to skip
# WATCH_EXTENSIONS=js,ts,jsx,tsx,json,md      # Comma-separated file extensions
# PROCESSING_DELAY=100                   # Delay (ms) between processing events
# PORT=3000                              # HTTP server port (omit to disable)

# --- Logging ---
# LOG_LEVEL=success                      # Levels: success | info | http | warn | error
# NODE_ENV=development                   # Set to "production" for JSON-only logs
# LOG_FORMAT                             # Set to "json" for structured console logs

# --- Slack Notifications ---
# SLACK_TOKEN=xoxb-...                   # Slack Bot Token (omit to disable)
# SLACK_CHANNEL=#general                 # Slack channel for alerts

# --- Email Notifications ---
# EMAIL_HOST=smtp.gmail.com              # SMTP server
# EMAIL_PORT=587                         # SMTP port (587=starttls, 465=ssl)
# EMAIL_USER                             # SMTP username (omit to disable)
# EMAIL_PASS                             # SMTP password
# EMAIL_FROM=watcher@localhost           # Sender address
# EMAIL_TO                               # Recipient address
